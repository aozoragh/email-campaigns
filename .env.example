# Copy this file to ".env" and fill in the values. Never commit your real .env.
# All variables are read server-side only.

# --- Google / Gmail OAuth ---
# Create at https://console.cloud.google.com/ (see README for full steps).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI in the Google OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/gmail/callback

# --- Microsoft / Outlook OAuth ---
# Create at https://entra.microsoft.com/ (App registrations). See README.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI (type: Web) in the app registration.
MICROSOFT_REDIRECT_URI=http://localhost:5173/auth/outlook/callback

# --- Session signing ---
# Secret used to sign the httpOnly session cookie. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
